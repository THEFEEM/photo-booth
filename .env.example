# Supabase Postgres (transaction pooler) — password มีอักขระพิเศษต้อง percent-encode
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=true

# Supabase (Realtime broadcast + Storage เก็บสลิป)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PromptPay รับเงิน (เบอร์โทร 10 หลัก หรือเลขบัตรประชาชน 13 หลัก)
PROMPTPAY_ID=0812345678

# หน้าพนักงาน
STAFF_PIN=123456
STAFF_SESSION_SECRET=change-me-to-a-long-random-string

# --- ยังไม่ใช้ (Phase ถัดไป: ตรวจสลิปอัตโนมัติผ่าน SlipOK) ---
# SLIPOK_BRANCH_ID=
# SLIPOK_API_KEY=
# MAX_SLIP_AGE_MINUTES=60
